{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@daycare-hub/shared": ["../../libs/shared/src/index.ts"],
      "@daycare-hub/shared/*": ["../../libs/shared/src/*"],
      "@daycare-hub/services": ["../../libs/services/src/index.ts"],
      "@daycare-hub/services/*": ["../../libs/services/src/*"],
      "@daycare-hub/hooks": ["../../libs/hooks/src/index.ts"],
      "@daycare-hub/hooks/*": ["../../libs/hooks/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "../../libs/shared/src/**/*.ts", "../../libs/services/src/**/*.ts", "../../libs/hooks/src/**/*.ts"]
}
